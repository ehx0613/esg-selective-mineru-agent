PDF_PARSER_BACKEND=auto
MINERU_AUTO_RUN_ENABLED=false
MINERU_COMMAND=mineru -p "{pdf}" -o "{output}" --backend pipeline --method auto --lang ch
MINERU_OUTPUT_ROOT=output/mineru_cache
MINERU_TIMEOUT_SECONDS=7200
SELECTIVE_MINERU_MAX_PAGES=12
SELECTIVE_MINERU_SCORE_THRESHOLD=35
MINERU_BATCH_SIZE=1
MINERU_LLM_REVIEW_ENABLED=false
MINERU_LLM_REVIEW_LOW_THRESHOLD=25
MINERU_LLM_REVIEW_HIGH_THRESHOLD=45
MINERU_LLM_REVIEW_MAX_PAGES=20

# 原 ESG 项目，用于复用 A 股 v5 60 字段 schema
ORIGINAL_ESG_PROJECT_ROOT=C:\Users\18130\PycharmProjects\爬虫\esg-multimodal-extraction-agent

# DashScope / OpenAI-compatible 模型配置
# 不要提交真实 key；可写入本地 .env 或通过 shell 环境变量注入
DASHSCOPE_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
TEXT_MODEL=qwen-plus-2025-09-11
VLM_MODEL=qwen-vl-plus
SCHEMA_JUDGE_MODEL=qwen3.6-flash
SCHEMA_JUDGE_FALLBACK_MODEL=qwen3.6-plus

LLM_EXTRACTION_ENABLED=true
LLM_MAX_CALLS_PER_REPORT=12
LLM_FIELD_BATCH_SIZE=6
RETRIEVER_MODE=simple
RETRIEVER_VECTOR_BACKEND=local
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_BATCH_SIZE=10
RAG_TOP_K=3
RAG_BM25_TOP_K=30
RAG_VECTOR_TOP_K=30
RAG_RRF_K=60

# 当前 MVP 只抽取和评估目标报告年度。后续多年份流程稳定后再扩展。
TARGET_REPORT_YEAR=2024
DATABASE_URL=sqlite:///data/esg_jobs.db
